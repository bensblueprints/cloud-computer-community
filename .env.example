# App
NODE_ENV=production
PORT=3001
BASE_DOMAIN=cloudcode.space
FRONTEND_URL=https://app.cloudcode.space

# Database (Supabase)
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...

# Authentication
JWT_SECRET=GENERATE_RANDOM_64_CHAR_STRING_HERE
CREDENTIAL_ENCRYPTION_KEY=GENERATE_RANDOM_32_BYTE_HEX_STRING

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SOLO=price_...
STRIPE_PRICE_TEAM=price_...
STRIPE_PRICE_ARMY=price_...

# Offer / Digital Products
STRIPE_PRICE_SKILLS_5=price_...
STRIPE_PRICE_SKILLS_15=price_...
STRIPE_OFFER_WEBHOOK_SECRET=whsec_...
ADMIN_EMAIL=admin@cloudcode.space

# Proxmox
PROXMOX_HOST=https://YOUR_PROXMOX_IP:8006
PROXMOX_USER=root@pam
PROXMOX_TOKEN_ID=root@pam!api-token
PROXMOX_TOKEN_SECRET=YOUR_TOKEN_SECRET_HERE
PROXMOX_NODE=your-node-name

# VM Templates (QEMU)
PROXMOX_TEMPLATE_SOLO=512
PROXMOX_TEMPLATE_TEAM=513
PROXMOX_TEMPLATE_ARMY=514

# Traefik
TRAEFIK_DYNAMIC_DIR=/etc/traefik/dynamic

# noVNC
NOVNC_TOKEN_SECRET=GENERATE_RANDOM_64_CHAR_STRING_HERE

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@cloudcode.space

# Go High Level (Agency API - creates sub-accounts for customers)
GHL_API_KEY=pit-xxxxx
GHL_COMPANY_ID=your-company-id

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# OVH DNS (Traefik wildcard cert)
OVH_ENDPOINT=ovh-ca
OVH_APPLICATION_KEY=...
OVH_APPLICATION_SECRET=...
OVH_CONSUMER_KEY=...
